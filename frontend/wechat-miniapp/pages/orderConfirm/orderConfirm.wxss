page {
  background: #f5f6fa;
}

.order-confirm-page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 地址区域 */
.address-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.address-tag {
  padding: 4rpx 12rpx;
  background: #ff6b35;
  color: #fff;
  font-size: 20rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.no-address {
  flex: 1;
  display: flex;
  align-items: center;
  color: #999;
  font-size: 30rpx;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 20rpx;
}

.address-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  opacity: 0.5;
}

/* 订单商品 */
.order-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.dish-list {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.dish-flavor {
  font-size: 24rpx;
  color: #999;
}

.dish-price {
  text-align: right;
}

.dish-price .price {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.dish-price .count {
  font-size: 24rpx;
  color: #999;
}

/* 配送信息 */
.delivery-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.delivery-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.delivery-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333;
}

.value {
  font-size: 28rpx;
  color: #666;
}

.remark-value {
  display: flex;
  align-items: center;
}

.remark-value .placeholder {
  color: #999;
}

.remark-value .text {
  color: #333;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tableware-options {
  display: flex;
  gap: 16rpx;
}

.tableware-options .option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.tableware-options .option.active {
  background: #fff5f2;
  color: #ff6b35;
  border: 2rpx solid #ff6b35;
}

/* 支付方式 */
.payment-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.payment-options {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.payment-option {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.payment-option .icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.payment-option .name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.payment-option .check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.payment-option .check.active {
  background: #ff6b35;
  border-color: #ff6b35;
  position: relative;
}

.payment-option .check.active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background: #fff;
  border-radius: 50%;
}

.payment-option.active .name {
  color: #ff6b35;
}

/* 底部占位 */
.footer-placeholder {
  height: 120rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-section {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.total-symbol {
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: bold;
}

.total-value {
  font-size: 40rpx;
  color: #ff6b35;
  font-weight: bold;
}

.submit-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8f5a 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.submit-btn.disabled {
  background: #ccc;
}
