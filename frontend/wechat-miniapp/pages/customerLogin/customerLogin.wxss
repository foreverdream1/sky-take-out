/* 顾客端登录页样式 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* 品牌区 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  padding-bottom: 60rpx;
}

.brand-logo {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* 店铺状态 */
.shop-status-banner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-bottom: 80rpx;
}

.shop-status-banner.open {
  background: rgba(255,255,255,0.95);
  color: #27ae60;
}

.shop-status-banner.closed {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

.status-dot {
  font-size: 20rpx;
}

/* 登录区 */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #333;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12);
  margin-bottom: 32rpx;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  text-align: center;
}

.link {
  color: #fff;
  text-decoration: underline;
}
