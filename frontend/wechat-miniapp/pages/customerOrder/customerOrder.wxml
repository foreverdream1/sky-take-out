<!-- 顾客端订单页 -->
<view class="order-page">

  <!-- 订单状态Tab -->
  <view class="status-tabs">
    <view
      class="tab-item {{activeStatus === -1 ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="-1"
    >
      全部
    </view>
    <view
      class="tab-item {{activeStatus === 1 ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="1"
    >
      待付款
    </view>
    <view
      class="tab-item {{activeStatus === 2 ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="2"
    >
      待接单
    </view>
    <view
      class="tab-item {{activeStatus === 4 ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="4"
    >
      派送中
    </view>
    <view
      class="tab-item {{activeStatus === 5 ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="5"
    >
      已完成
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view
    class="order-list"
    scroll-y="true"
    bindscrolltolower="loadMore"
    wx:if="{{orderList.length > 0}}"
  >
    <view class="order-card" wx:for="{{orderList}}" wx:key="id">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-number">订单号：{{item.number}}</text>
        <view class="order-status tag-{{statusTagMap[item.status]}}">
          {{statusTextMap[item.status]}}
        </view>
      </view>

      <!-- 商品信息 -->
      <view class="order-goods">
        <text class="goods-text" wx:if="{{item.orderDishes}}">{{item.orderDishes}}</text>
        <text class="goods-text" wx:else>查看详情</text>
        <text class="goods-count">共{{item.number || 1}}件</text>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-left">
          <text class="order-time">{{item.orderTime}}</text>
          <text class="order-amount">¥{{item.amount}}</text>
        </view>
        <view class="order-actions">
          <!-- 待付款：去付款 + 取消 -->
          <view class="action-btn btn-cancel" wx:if="{{item.status === 1}}" bindtap="cancelOrder" data-id="{{item.id}}">
            取消订单
          </view>
          <view class="action-btn btn-pay" wx:if="{{item.status === 1}}" bindtap="payOrder" data-id="{{item.id}}">
            去付款
          </view>
          <!-- 已完成：再来一单 -->
          <view class="action-btn btn-repeat" wx:if="{{item.status === 5}}" bindtap="repeatOrder" data-id="{{item.id}}">
            再来一单
          </view>
          <!-- 派送中：确认收货（可选） -->
          <view class="action-btn btn-confirm" wx:if="{{item.status === 4}}" bindtap="confirmReceive" data-id="{{item.id}}">
            确认收货
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <loading-more 
      wx:if="{{orderList.length > 0}}"
      loading="{{loadingMore}}"
      noMore="{{!hasMore}}"
    />
  </scroll-view>

  <!-- 空状态 -->
  <empty wx:if="{{orderList.length === 0 && !loading}}" text="暂无相关订单" image="/assets/icons/no-order.png">
    <view class="empty-btn" bindtap="goShopping">去点餐</view>
  </empty>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading && orderList.length === 0}}">
    <text>加载中...</text>
  </view>

</view>
