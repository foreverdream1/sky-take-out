/* 顾客端"我的"页面样式 */
.my-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 60rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  padding: 60rpx 40rpx 80rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.user-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
  background: #f0f0f0;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.4);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* 快捷功能 */
.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: #fff;
  margin: -40rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.shortcut-icon {
  font-size: 48rpx;
}

.shortcut-label {
  font-size: 24rpx;
  color: #666;
}

/* 菜单列表 */
.menu-section {
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-btn {
  margin: 32rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
  padding: 32rpx;
  font-size: 30rpx;
  color: #e74c3c;
  font-weight: 600;
}

.app-version {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 16rpx;
}
